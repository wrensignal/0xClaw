{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wrenos.dev/schemas/strategy-builder/nl-rule-translation.schema.json",
  "title": "Strategy Builder NL Rule Translation Contract",
  "type": "object",
  "required": ["request_id", "strategy_name", "intent", "entry", "exit", "risk", "validation", "generated_at"],
  "properties": {
    "request_id": {"type": "string", "minLength": 1},
    "strategy_name": {"type": "string", "minLength": 1},
    "intent": {"type": "string", "minLength": 1},
    "entry": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "exit": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "risk": {
      "type": "object",
      "required": ["max_position_pct", "hard_stop_loss_pct"],
      "properties": {
        "max_position_pct": {"type": "number", "minimum": 0.001, "maximum": 0.5},
        "hard_stop_loss_pct": {"type": "number", "minimum": 0.01, "maximum": 0.5}
      },
      "additionalProperties": true
    },
    "validation": {
      "type": "object",
      "required": ["ok", "warnings"],
      "properties": {
        "ok": {"type": "boolean"},
        "warnings": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": true
}
