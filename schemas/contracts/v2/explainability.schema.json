{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wrenos.dev/schemas/contracts/v2/explainability.schema.json",
  "title": "Explainability Contract v2",
  "type": "object",
  "required": ["version", "decision", "confidence", "reasons", "evidence", "compat", "generated_at"],
  "properties": {
    "version": {"const": "2.0.0"},
    "decision": {"type": "string"},
    "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
    "reasons": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "compat": {
      "type": "object",
      "required": ["migrated_from", "migration_rule"],
      "properties": {
        "migrated_from": {"type": ["string", "null"]},
        "migration_rule": {"type": "string"}
      }
    },
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": true
}
