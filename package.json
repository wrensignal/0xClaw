{
  "name": "wrenos",
  "private": true,
  "version": "0.1.0",
  "description": "WrenOS OpenClaw-compatible crypto agent control plane",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wrensignal/wrenOS.git"
  },
  "homepage": "https://github.com/wrensignal/wrenOS#readme",
  "bugs": {
    "url": "https://github.com/wrensignal/wrenOS/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "wrenos": "packages/cli/src/index.mjs",
    "0xclaw": "packages/cli/src/index.mjs"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "npm run test --workspaces --if-present",
    "lint": "node scripts/lint.mjs",
    "typecheck": "node scripts/typecheck.mjs",
    "example:paper": "node examples/wrenos-paper-happy-path/run.mjs",
    "smoke:cli": "node scripts/cli-smoke.mjs",
    "verify": "npm run build && npm run lint && npm run typecheck && npm run test && npm run smoke:cli && npm run smoke:bootstrap && npm run acceptance:cli",
    "railway:preflight": "node scripts/railway-env-preflight.mjs",
    "railway:health": "node scripts/railway-postdeploy-health.mjs",
    "railway:first-run": "node scripts/railway-first-run.mjs",
    "smoke:bootstrap": "node scripts/bootstrap-smoke.mjs",
    "acceptance:cli": "node scripts/cli-acceptance.mjs",
    "artifacts:generate": "node scripts/generate-observability-samples.mjs",
    "artifacts:validate": "node scripts/validate-observability-artifacts.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
