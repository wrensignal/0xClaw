{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wrenos.ai/schemas/contracts/env.operator.schema.json",
  "title": "WrenOS operator (OpenClaw/custom) environment contract",
  "allOf": [
    {
      "$ref": "./env.base.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "OPENCLAW_OPERATOR_MODE": {
          "type": "string",
          "enum": ["true", "false"],
          "description": "Enable expanded operator controls"
        },
        "OPENCLAW_RUNTIME_TOPOLOGY": {
          "type": "string",
          "description": "Operator runtime topology selection"
        },
        "OPENCLAW_ADAPTER_OVERRIDES": {
          "type": "string",
          "description": "JSON override map for adapter routing"
        },
        "OPENCLAW_MCP_SERVER_MAP": {
          "type": "string",
          "description": "JSON map for custom MCP server wiring"
        }
      },
      "additionalProperties": true
    }
  ]
}
