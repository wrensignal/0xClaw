{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wrenos.ai/schemas/contracts/env.base.schema.json",
  "title": "WrenOS shared environment contract",
  "type": "object",
  "properties": {
    "PROFILE": {
      "type": "string",
      "description": "Runtime profile name"
    },
    "OPENCLAW_API_KEY": {
      "type": "string",
      "minLength": 1,
      "description": "OpenClaw gateway API key"
    },
    "TELEGRAM_BOT_TOKEN": {
      "type": "string",
      "minLength": 1,
      "description": "Telegram bot token for operator notifications"
    },
    "AGENT_WALLET_PRIVATE_KEY": {
      "type": "string",
      "description": "Only required when execution-enabled mode is explicitly turned on"
    }
  },
  "required": ["PROFILE", "OPENCLAW_API_KEY", "TELEGRAM_BOT_TOKEN"],
  "additionalProperties": true
}
