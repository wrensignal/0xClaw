{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wrenos.ai/schemas/contracts/env.hosted.schema.json",
  "title": "WrenOS hosted (Railway) environment contract",
  "allOf": [
    {
      "$ref": "./env.base.schema.json"
    },
    {
      "type": "object",
      "description": "Hosted lane intentionally keeps a narrow env surface.",
      "not": {
        "anyOf": [
          { "required": ["OPENCLAW_OPERATOR_MODE"] },
          { "required": ["OPENCLAW_RUNTIME_TOPOLOGY"] },
          { "required": ["OPENCLAW_ADAPTER_OVERRIDES"] },
          { "required": ["OPENCLAW_MCP_SERVER_MAP"] }
        ]
      }
    }
  ]
}
