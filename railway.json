{
  "$schema": "https://railway.com/railway.schema.json",
  "name": "WrenOS Agent",
  "description": "Crypto trading agent with private inference and meme discovery",
  "services": [
    {
      "name": "agent",
      "source": "github:wrensignal/wrenOS",
      "envVars": {
        "PROFILE": {
          "description": "Agent profile",
          "default": "research-agent"
        },
        "SPEAKEASY_BASE_URL": {
          "description": "Speakeasy inference endpoint",
          "default": "https://api.speakeasyrelay.com"
        },
        "SPEAKEASY_API_KEY": {
          "description": "Optional API key"
        },
        "AGENT_WALLET_PRIVATE_KEY": {
          "description": "Agent hot wallet private key",
          "sensitive": true
        },
        "OPENCLAW_API_KEY": {
          "description": "OpenClaw API key",
          "sensitive": true
        }
      }
    }
  ]
}
